  "subtopics": [
    {
      "id": 1,
      "roadmap_id": 1,
      "technology_id": 1,
      "module_id": 4,
      "topic_id": 12,
      "slug": "html-header-and-nav-elements",
      "title": "HTML Header and Navigation Elements",
      "description": "The header and nav elements define the top region and link structure of a page or section in semantic HTML.",
      "content": [
        {
          "type": "paragraph",
          "text": [
            {
              "value": "The "
            },
            {
              "value": "<header>",
              "bold": true,
              "highlight": true,
              "link": "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/header"
            },
            {
              "value": " element represents an introductory region for its nearest sectioning ancestor, which can be the page itself, an "
            },
            {
              "value": "<article>",
              "bold": true,
              "highlight": true,
              "link": "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/article"
            },
            {
              "value": ", or a "
            },
            {
              "value": "<section>",
              "bold": true,
              "highlight": true,
              "link": "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/section"
            },
            {
              "value": ". It typically contains a logo, site name, or section heading. The "
            },
            {
              "value": "<nav>",
              "bold": true,
              "highlight": true,
              "link": "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/nav"
            },
            {
              "value": " element is reserved for "
            },
            {
              "value": "major navigation blocks",
              "bold": true
            },
            {
              "value": " only, such as the primary site menu or a breadcrumb trail. Minor groups of links, such as those in a footer, do not require a "
            },
            {
              "value": "<nav>",
              "bold": true,
              "highlight": true
            },
            {
              "value": " wrapper. When multiple "
            },
            {
              "value": "<nav>",
              "bold": true,
              "highlight": true
            },
            {
              "value": " elements exist on a page, each should carry a distinct "
            },
            {
              "value": "aria-label",
              "bold": true,
              "highlight": true,
              "link": "https://developer.mozilla.org/en-US/docs/Web/Accessibility/ARIA/Attributes/aria-label"
            },
            {
              "value": " so screen readers can tell them apart."
            }
          ]
        },
        {
          "type": "callout",
          "variant": "warning",
          "title": "nav is not for every group of links",
          "text": "Only wrap links in a nav element when they represent a major navigation block. Footer legal links, tag lists, and pagination can use plain ul elements without nav unless they are primary navigation controls."
        }
      ],
      "examples": [
        {
          "title": "Header with Primary and Secondary Navigation",
          "description": "Shows a page-level header containing a logo and two labelled nav elements, demonstrating correct aria-label usage to distinguish between navigation landmarks for screen reader users.",
          "code_snippet": "<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>Header and Nav Example</title>\n    <style>\n      header { background: #0f3460; color: white; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; }\n      nav a { color: white; margin-left: 1rem; text-decoration: none; font-size: 0.9rem; }\n      .breadcrumb { background: #f0f0f0; padding: 0.5rem 2rem; font-size: 0.85rem; }\n      .breadcrumb a { color: #0f3460; text-decoration: none; }\n    </style>\n  </head>\n  <body>\n    <header>\n      <span>Acme Docs</span>\n      <!-- aria-label distinguishes this from other nav elements on the page -->\n      <nav aria-label=\"Primary\">\n        <a href=\"/\">Home</a>\n        <a href=\"/guides\">Guides</a>\n        <a href=\"/api\">API</a>\n        <a href=\"/blog\">Blog</a>\n      </nav>\n    </header>\n    <!-- Second nav with its own aria-label so screen readers name it separately -->\n    <nav aria-label=\"Breadcrumb\" class=\"breadcrumb\">\n      <a href=\"/\">Home</a> /\n      <a href=\"/guides\">Guides</a> /\n      <span>Getting Started</span>\n    </nav>\n    <main>\n      <h1>Getting Started</h1>\n      <p>Welcome to the Acme documentation.</p>\n    </main>\n  </body>\n</html>",
          "output": "A dark blue header bar spans the top of the page with 'Acme Docs' on the left and four navigation links on the right. Below it, a light grey breadcrumb bar shows 'Home / Guides / Getting Started'. Screen readers announce two distinct navigation landmarks: 'Primary navigation' and 'Breadcrumb navigation', allowing users to jump to either independently.",
