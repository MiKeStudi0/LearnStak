  "subtopics": [
    {
      "id": 1,
      "roadmap_id": 1,
      "technology_id": 1,
      "module_id": 5,
      "topic_id": 17,
      "slug": "description-list-elements",
      "title": "Description List Elements",
      "description": "The dl element pairs terms with descriptions, making it ideal for glossaries, metadata, and FAQs.",
      "content": [
        {
          "type": "paragraph",
          "text": [
            {
              "value": "A description list is created with "
            },
            {
              "value": "<dl>",
              "bold": true,
              "highlight": true,
              "link": "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/dl"
            },
            {
              "value": ", which acts as the container. Inside it, "
            },
            {
              "value": "<dt>",
              "bold": true,
              "highlight": true,
              "link": "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/dt"
            },
            {
              "value": " marks a "
            },
            {
              "value": "description term",
              "bold": true
            },
            {
              "value": " and "
            },
            {
              "value": "<dd>",
              "bold": true,
              "highlight": true,
              "link": "https://developer.mozilla.org/en-US/docs/Web/HTML/Element/dd"
            },
            {
              "value": " marks the "
            },
            {
              "value": "description details",
              "bold": true
            },
            {
              "value": " that follow it. One "
            },
            {
              "value": "<dt>",
              "bold": true,
